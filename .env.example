# Copy this file to .env and paste the token from:
# Cloudflare Zero Trust > Networks > Tunnels > your tunnel > Install connector
#
# This is the only secret the stack needs. The contact form sends no server-side
# email — it opens the visitor's mail client (mailto: contact@erenisiklab.com,
# forwarded to the owner's inbox by Cloudflare Email Routing).
TUNNEL_TOKEN=replace-with-your-cloudflare-tunnel-token
