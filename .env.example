# Copy this file to .env and paste the token from:
# Cloudflare Zero Trust > Networks > Tunnels > your tunnel > Install connector
TUNNEL_TOKEN=replace-with-your-cloudflare-tunnel-token

# Optional: enable live contact form email delivery through Resend (recommended).
# Without any provider values below, the API runs in simulation mode and still
# returns successful transmission confirmations for local testing.
RESEND_API_KEY=
CONTACT_TO_EMAIL=
CONTACT_FROM_EMAIL="Eren Isik Lab <contact@erenisiklab.com>"

# Alternative provider: Cloudflare Email Service (beta). Used only when
# RESEND_API_KEY is empty (Resend takes precedence when both are set). Free when
# CONTACT_TO_EMAIL is a verified destination in Cloudflare Email Routing;
# requires the domain onboarded for email sending (MX/SPF/DKIM/DMARC) and a
# token with the email-sending permission.
CF_ACCOUNT_ID=
CF_EMAIL_TOKEN=
